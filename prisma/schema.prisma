generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id        String   @id @default(cuid())
  mode      String
  title     String
  level     String
  focus     String
  prompts   String
  answers   String   @default("{}")
  feedback  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
